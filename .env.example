# Lead Platform — example environment file.
# Copy to .env (gitignored) and fill in values.

# ---- App ----
NODE_ENV=development
APP_URL=http://localhost:3000
PORT=3000

# ---- Database ----
# Used by Next.js app at runtime and by Drizzle CLI for migrations.
DATABASE_URL=postgres://lead:lead@localhost:5432/lead

# ---- Auth (Auth.js / next-auth) ----
# AUTH_SECRET: generate with `openssl rand -hex 32`. Required.
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Google OAuth — create at https://console.cloud.google.com/
# Authorized redirect URI: ${AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Owner bootstrap: first user with this email becomes super_admin on first login.
OWNER_EMAIL=

# ---- Master encryption key ----
# Used to encrypt workspace_secrets at rest (AES-256-GCM). Generate once
# with `openssl rand -hex 32`. NEVER rotate without re-encrypting all
# secrets — see docs/DEPLOYMENT.md.
MASTER_KEY=

# ---- Storage (file storage abstraction) ----
# Phase 1: local filesystem implementation. Phase 9+: S3-compatible.
STORAGE_PROVIDER=local
STORAGE_LOCAL_ROOT=./storage

# When STORAGE_PROVIDER=s3 (later):
# S3_BUCKET=
# S3_REGION=
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# ---- Job queue ----
# `memory` runs handlers on the next microtask in-process (fine for dev,
# loses jobs on restart). `bullmq` requires Redis; jobs are durable and
# can be processed by any number of worker processes.
JOB_QUEUE_PROVIDER=memory
# JOB_QUEUE_PROVIDER=bullmq
REDIS_URL=redis://localhost:6379

# ---- AI provider ----
# Phase 1: mock provider returns deterministic stubs. Real providers wired later.
AI_PROVIDER=mock
# AI_PROVIDER=anthropic | openai | gemini | deepseek | mock
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=

# ---- Search provider ----
# `mock` is deterministic and zero-cost (default). `serpapi` requires a
# key — either workspace-level (workspace_secrets `serpapi.apiKey`) or
# the platform-default below.
SEARCH_PROVIDER=mock
# SEARCH_PROVIDER=serpapi

# Platform-default SerpAPI key. Workspaces that haven't set their own
# `serpapi.apiKey` workspace secret fall back to this. Optional — the
# platform can run with mock-only search if you don't pay SerpAPI.
SERPAPI_KEY=
# GEMINI_GROUNDING_API_KEY=

# ---- Telemetry / cost tracking ----
USAGE_LOG_ENABLED=true
